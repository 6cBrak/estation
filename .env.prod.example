# ════════════════════════════════════════════════════════════════════════════
#  E-Station — Variables d'environnement production
#  Copier ce fichier en .env.prod et remplir TOUTES les valeurs CHANGE_ME
#  Ne jamais committer .env.prod dans git !
# ════════════════════════════════════════════════════════════════════════════

# ─── Django ──────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=CHANGE_ME_long_random_string_50_chars_minimum

DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=estation.gsoft-bf.com

# ─── Base de données ─────────────────────────────────────────────────────────
# Le hostname doit correspondre au container_name dans docker-compose.prod.yml
DATABASE_URL=postgresql://estation:CHANGE_ME@estation_db:5432/estation
POSTGRES_DB=estation
POSTGRES_USER=estation
POSTGRES_PASSWORD=CHANGE_ME_mot_de_passe_fort

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://estation.gsoft-bf.com

# ─── Email (optionnel — laisser vide pour désactiver) ────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=E-Station <noreply@gsoft-bf.com>

# Destinataire des rapports automatiques
BOSS_EMAIL=
